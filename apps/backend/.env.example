# Copy to .env and fill in per environment. Never commit real secrets.

PORT=3000
NODE_ENV=development

# Data source for read endpoints:
#   memory   - serve the seeded demo dataset with no database (default)
#   postgres - read from a real database via DATABASE_URL
DATA_SOURCE=memory

# Supabase / Postgres (required only when DATA_SOURCE=postgres)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# Plaid (added in Phase 6)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=

# Calendar (added in Phase 6)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Push notifications (added in Phase 6)
EXPO_ACCESS_TOKEN=

# AI service abstraction (provider not locked yet, see src/ai)
AI_PROVIDER=
AI_API_KEY=
