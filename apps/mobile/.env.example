# Copy to .env.local for local development. Never commit real values.
# Only EXPO_PUBLIC_* vars are readable by the app; none of these are secret.

# API mode: fixture (default, in-app data, no network) | live (real backend)
EXPO_PUBLIC_API_MODE=fixture

# Base URL of the backend when EXPO_PUBLIC_API_MODE=live
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase (used once real auth lands in a later checkpoint; anon key is publishable)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
